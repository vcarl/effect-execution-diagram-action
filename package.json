{
  "name": "effect-execution-diagram-action",
  "version": "0.1.0",
  "description": "GitHub Action that generates Mermaid diagrams from Effect-TS code changes",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build build/index.js -o dist",
    "test": "vitest",
    "lint": "tsc --noEmit",
    "generate-examples": "tsx scripts/generate-examples.ts"
  },
  "keywords": [
    "effect-ts",
    "mermaid",
    "github-action",
    "diagram"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@effect/language-service": "^0.77.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.0",
    "effect": "^3.19.19",
    "tsx": "^4.21.0",
    "vitest": "^3.0.0"
  }
}
